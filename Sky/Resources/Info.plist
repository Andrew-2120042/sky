<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>Sky</string>
	<key>CFBundlePackageType</key>
	<string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
	<key>CFBundleShortVersionString</key>
	<string>1.0</string>
	<key>CFBundleVersion</key>
	<string>1</string>
	<key>LSMinimumSystemVersion</key>
	<string>$(MACOSX_DEPLOYMENT_TARGET)</string>
	<key>LSUIElement</key>
	<true/>
	<key>NSContactsUsageDescription</key>
	<string>Sky needs access to Contacts to send messages and emails to your contacts.</string>
	<key>NSCalendarsUsageDescription</key>
	<string>Sky needs access to Calendars to create and manage calendar events.</string>
	<key>NSRemindersUsageDescription</key>
	<string>Sky needs access to Reminders to create and manage reminders.</string>
	<key>NSAppleEventsUsageDescription</key>
	<string>Sky needs to send Apple Events to automate apps on your Mac.</string>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>Sky uses speech recognition to accept voice commands.</string>
	<key>NSUserNotificationUsageDescription</key>
	<string>Sky sends notifications for scheduled meeting reminders.</string>
	<key>NSScreenRecordingUsageDescription</key>
	<string>Sky needs Screen Recording access to capture your screen for computer use commands.</string>
</dict>
</plist>
